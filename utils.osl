def ensureDb() (
    if !fs.exists("./db") (
        fs.mkdirAll("./db")
    )
    if !fs.exists("./db/links") (
        fs.mkdirAll("./db/links")
    )
    if !fs.exists("./db/users") (
        fs.mkdirAll("./db/users")
    )
)

def loadSessions() (
    ensureDb()
    if !fs.exists("./db/sessions.json") (
        return
    )
    string raw = fs.readFile("./db/sessions.json")
    object data = json.parse(raw, { type: "object" }) catch (
        return
    )
    if data.sessions != null (
        sessions = data.sessions
    )
    if data.userData != null (
        userData = data.userData
    )
)

def saveSessions() (
    ensureDb()
    fs.writeFile("./db/sessions.json", {
        "sessions": sessions,
        "userData": userData,
        "saved_at": time.Now().Unix()
    }.toStr())
)

def randomString(int length) string (
    string chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    string result = ""
    for i length (
        result ++= chars[random(1, chars.len)].toStr()
    )
    return result
)

def abortUnauthorized(*gin.Context c) (
    string path = c.Request.URL.Path
    if path.startsWith("/api") (
        c.JSON(401, { ok: false, error: "not authenticated" })
    ) else (
        c.Redirect(302, "/auth")
    )
    c.Abort()
)

def handleRedirect(*gin.Context c) (
    string id = c.Param("id")
    if id == "" (
        c.String(404, "not found")
        return
    )
    object res = getLink(id)
    if res.ok != true (
        c.String(404, "not found")
        return
    )
    object link = res.link
    c.Redirect(302, link.to.toStr())
)

def validateDestination(string url) string (
    if url == "" (
        return "missing destination"
    )
    if !url.startsWith("https://") and !url.startsWith("http://") (
        return "destination must start with http:// or https://"
    )
    return ""
)